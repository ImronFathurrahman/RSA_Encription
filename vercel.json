{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.0"
    },
    "*.php": {
      "runtime": "vercel-php@0.7.0"
    }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/rsa_enkripsi_url.php"
    },
    {
      "src": "/(.*)",
      "dest": "/rsa_enkripsi_url.php"
    }
  ]
}
